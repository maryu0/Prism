# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-string
# Generate your own: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-generated-fernet-key

# --- MongoDB Atlas ---
# From Atlas: Database > Connect > Drivers > copy the connection string,
# then replace <password> with your database user's password.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-name>.mongodb.net/prism?retryWrites=true&w=majority

# --- Neo4j Aura ---
# From Aura: the "Connection URI", plus the username/password shown once
# when the instance was created (save them somewhere safe immediately).
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-aura-generated-password

# --- Upstash Redis ---
# From Upstash: Database > REST/Redis tab > "Redis Connect" URL (rediss://...)
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:<port>

# --- Chroma (local/embedded for now, no account needed) ---
CHROMA_PERSIST_DIR=./.chroma

# --- Filled in during later phases, leave blank for now ---
GITHUB_TOKEN=
# Free tier at console.groq.com — primary LLM provider for RAG chat (Phase 6)
GROQ_API_KEY=
# Optional fallback provider, not yet wired in
GEMINI_API_KEY=
